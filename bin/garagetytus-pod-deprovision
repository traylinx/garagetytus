#!/usr/bin/env bash
# garagetytus-pod-deprovision — undo what garagetytus-pod-provision did.
#
# Per Q13 verdict: revoke-on-disconnect.
#  - Deletes per-bucket Garage keys (`pod-<pod-id>-<bucket>`)
#  - Removes credentials.json + _last-provision.json from the pod
#  - Strips the shared-folder fragment from config.user.json (split at marker)
#  - Optionally restarts the pod so the overlay change takes effect
#
# Usage:
#   garagetytus-pod-deprovision <pod-id> [--bucket NAME...] [--all-buckets]
#                               [--droplet HOST] [--no-restart] [--dry-run]
#
# If --all-buckets: revoke every key whose name matches `pod-<pod-id>-*`.
# Otherwise: only the specified --bucket grants are revoked.

set -euo pipefail

DROPLET="${GARAGETYTUS_DROPLET:-root@212.227.205.146}"
DROPLET_EXPLICIT=0
DROPLET_CONFIG="/var/lib/garagetytus/config/garagetytus.toml"
WANNOLOT_NETNS="wannolot-01"
MARKER="<!-- garagetytus:shared-folders v1 -->"

POD_ID=""
BUCKETS=()
ALL_BUCKETS=0
NO_RESTART=0
DRY_RUN=0

err() { printf 'pod-deprovision: %s\n' "$*" >&2; exit 1; }
note() { printf 'pod-deprovision: %s\n' "$*" >&2; }
usage() { sed -n '1,18p' "$0" | sed 's|^# \{0,1\}||'; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --bucket)        BUCKETS+=("$2"); shift 2;;
        --all-buckets)   ALL_BUCKETS=1; shift;;
        --droplet)       DROPLET="$2"; DROPLET_EXPLICIT=1; shift 2;;
        --no-restart)    NO_RESTART=1; shift;;
        --dry-run)       DRY_RUN=1; shift;;
        -h|--help)       usage; exit 0;;
        --) shift; break;;
        -*) err "unknown flag: $1 (try --help)";;
        *)
            if [[ -z "$POD_ID" ]]; then POD_ID="$1"
            else err "unexpected positional: $1"; fi
            shift;;
    esac
done

[[ -n "$POD_ID" ]] || err "missing <pod-id> (try --help)"
[[ "${#BUCKETS[@]}" -gt 0 || "$ALL_BUCKETS" -eq 1 ]] \
    || err "need --bucket NAME (repeatable) or --all-buckets"

resolve_route_selector() {
    local selector="$1"
    local state_path="${TYTUS_STATE_PATH:-}"
    if [[ -z "$state_path" ]]; then
        state_path="${HOME}/Library/Application Support/tytus/state.json"
    fi
    [[ -f "$state_path" ]] || return 1
    python3 - "$state_path" "$selector" <<'PY'
import json, os, re, sys, urllib.parse, urllib.request
path, selector = sys.argv[1], sys.argv[2]
try:
    data = json.load(open(path))
except Exception:
    sys.exit(1)
selector_l = selector.lower()

def droplet_ip_from_provider_config(pod_id, route_id):
    secret = data.get("secret_key") or ""
    agent_user = data.get("agent_user_id") or ""
    if not (secret and agent_user and pod_id and route_id):
        return ""
    base = (
        os.environ.get("TYTUS_PROVIDER_URL")
        or os.environ.get("TYTUS_API_BASE_URL")
        or data.get("api_base_url")
        or "https://tytus.traylinx.com"
    ).rstrip("/")
    qs = urllib.parse.urlencode({"pod_id": str(pod_id).zfill(2), "route_id": route_id})
    req = urllib.request.Request(
        f"{base}/pod/config/download?{qs}",
        headers={"X-Agent-Secret-Token": secret, "X-Agent-User-Id": agent_user},
    )
    try:
        with urllib.request.urlopen(req, timeout=8) as resp:
            text = resp.read().decode("utf-8", "replace")
    except Exception:
        return ""
    m = re.search(r"(?im)^\\s*Endpoint\\s*=\\s*([^:\\s]+):\\d+", text)
    return m.group(1) if m else ""

for key in ("pods", "agents", "included"):
    rows = data.get(key) or []
    if not isinstance(rows, list):
        continue
    for row in rows:
        if not isinstance(row, dict):
            continue
        candidates = [row.get("route_id"), row.get("id")]
        if any(str(v).lower() == selector_l for v in candidates if v):
            raw_pod_id = row.get("pod_id")
            if raw_pod_id is None or str(raw_pod_id).strip() == "":
                sys.exit(1)
            pod_id = str(raw_pod_id).zfill(2)
            droplet_ip = row.get("droplet_ip") or ""
            if not droplet_ip:
                route_id = row.get("route_id") or row.get("id") or selector
                droplet_ip = droplet_ip_from_provider_config(pod_id, str(route_id))
            print(f"{pod_id}\t{droplet_ip}")
            sys.exit(0)
sys.exit(1)
PY
}

ORIGINAL_POD_ID="$POD_ID"
case "$POD_ID" in
    wannolot-*|tytus-*) POD_NUM="${POD_ID##*-}";;
    *) POD_NUM="$POD_ID";;
esac
if [[ ! "$POD_NUM" =~ ^[0-9]+$ ]]; then
    resolved="$(resolve_route_selector "$POD_NUM" || true)"
    [[ -n "$resolved" ]] || err "pod selector ${ORIGINAL_POD_ID} is not numeric and was not found in local Tytus state"
    POD_NUM="${resolved%%$'\t'*}"
    resolved_ip="${resolved#*$'\t'}"
    if [[ "$DROPLET_EXPLICIT" -eq 0 && -n "$resolved_ip" && "$resolved_ip" != "$resolved" ]]; then
        DROPLET="root@${resolved_ip}"
    fi
    note "resolved route selector ${ORIGINAL_POD_ID} -> pod ${POD_NUM} on ${DROPLET}"
fi
POD_LABEL="wannolot-${POD_NUM}"
CONTAINER="tytus-${POD_NUM}"

run_droplet() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        printf 'DRY: ssh %s %s\n' "$DROPLET" "$*" >&2; return 0
    fi
    ssh -o BatchMode=yes "$DROPLET" "$@"
}
run_garage() {
    run_droplet "WPID=\$(docker inspect -f '{{.State.Pid}}' ${WANNOLOT_NETNS}) && \
                 nsenter -t \$WPID -n -- /root/.local/bin/garage -c ${DROPLET_CONFIG} $*"
}
run_pod() {
    local cmd="$*"
    local encoded
    encoded=$(printf '%s' "$cmd" | base64 | tr -d '\n')
    run_droplet "printf '%s' '${encoded}' | base64 -d | docker exec -i ${CONTAINER} sh"
}

# ── 1. resolve which bucket grants to revoke ───────────────────────
note "phase 1/4 — resolve grants to revoke for ${POD_LABEL}"
if [[ "$ALL_BUCKETS" -eq 1 ]]; then
    if [[ "$DRY_RUN" -eq 0 ]]; then
        found=()
        while IFS= read -r grant; do
            [[ -n "$grant" ]] && found+=("$grant")
        done < <(run_garage "key list" \
            | awk -v prefix="pod-${POD_NUM}-" '$3 ~ "^"prefix {print $1" "$3}')
    else
        found=("DRY00 pod-${POD_NUM}-DRYALL")
    fi
else
    found=()
    for bucket in "${BUCKETS[@]}"; do
        key_name="pod-${POD_NUM}-${bucket}"
        if [[ "$DRY_RUN" -eq 1 ]]; then
            found+=("DRY00 ${key_name}")
        else
            id=$(run_garage "key list" 2>/dev/null \
                | awk -v n="$key_name" '$3==n {print $1; exit}')
            if [[ -n "$id" ]]; then
                found+=("$id $key_name")
            else
                note "  no grant for ${key_name} — skipping"
            fi
        fi
    done
fi

if [[ "${#found[@]}" -eq 0 ]]; then
    note "no grants matched — nothing to revoke on droplet"
fi

# ── 2. revoke each Garage key ──────────────────────────────────────
note "phase 2/4 — revoke Garage keys"
for entry in "${found[@]}"; do
    [[ -z "$entry" ]] && continue
    id="${entry%% *}"
    name="${entry##* }"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        note "  dry: would delete ${name} (id=${id})"
    else
        run_garage "key delete --yes ${id}" >/dev/null
        note "  deleted ${name} (id=${id})"
    fi
done

# ── 3. strip pod-side credentials + system-prompt fragment ────────
note "phase 3/4 — strip credentials + prompt fragment from pod"
if [[ "$DRY_RUN" -eq 0 ]]; then
    state=$(run_droplet "docker inspect -f '{{.State.Status}}' ${CONTAINER}" 2>/dev/null || true)
    if [[ "$state" != "running" ]]; then
        note "  container ${CONTAINER} not running (state=${state:-missing}) — skipping pod-side cleanup"
    else
        # If specific buckets requested, strip just those entries from
        # credentials.json. If --all-buckets or that leaves it empty,
        # delete credentials.json entirely.
        if [[ "$ALL_BUCKETS" -eq 1 ]]; then
            run_pod "rm -f /app/workspace/.garagetytus/credentials.json /app/workspace/.garagetytus/_last-provision.json"
            note "  removed credentials.json + _last-provision.json"
        else
            # Filter out revoked buckets, keep the rest
            for bucket in "${BUCKETS[@]}"; do
                run_pod "jq --arg b ${bucket} '.buckets |= map(select(.name != \$b))' /app/workspace/.garagetytus/credentials.json > /tmp/c.json && mv /tmp/c.json /app/workspace/.garagetytus/credentials.json"
            done
            remaining=$(run_pod "jq '.buckets | length' /app/workspace/.garagetytus/credentials.json" 2>/dev/null || echo 0)
            if [[ "$remaining" -eq 0 ]]; then
                run_pod "rm -f /app/workspace/.garagetytus/credentials.json /app/workspace/.garagetytus/_last-provision.json"
                note "  no buckets left — removed credentials.json + _last-provision.json"
            else
                note "  credentials.json: ${remaining} bucket(s) remain"
            fi
        fi

        # Strip our fragment from config.user.json's systemPromptOverride
        # IFF this was a full deprovision (no buckets remain).
        full_strip=0
        if [[ "$ALL_BUCKETS" -eq 1 ]]; then
            full_strip=1
        elif ! run_pod "test -f /app/workspace/.garagetytus/credentials.json"; then
            full_strip=1
        fi
        if [[ "$full_strip" -eq 1 ]]; then
            current_overlay=$(run_pod "cat /app/workspace/.openclaw/config.user.json 2>/dev/null || echo '{}'")
            overlay_prompt=$(printf '%s' "$current_overlay" \
                | jq -r '.agents.defaults.systemPromptOverride // ""')
            if [[ "$overlay_prompt" == *"$MARKER"* ]]; then
                cleaned=$(printf '%s' "$overlay_prompt" \
                    | awk -v m="$MARKER" 'BEGIN{p=1} index($0,m){p=0} p{print}' \
                    | sed -e ':a' -e '/^\s*$/{$d;N;ba' -e '}')
                if [[ -z "${cleaned// /}" ]]; then
                    new_overlay=$(printf '%s' "$current_overlay" \
                        | jq 'del(.agents.defaults.systemPromptOverride)')
                else
                    new_overlay=$(printf '%s' "$current_overlay" \
                        | jq --arg sp "$cleaned" '.agents.defaults.systemPromptOverride = $sp')
                fi
                printf '%s' "$new_overlay" \
                    | run_droplet "cat > /tmp/config.user.json"
                run_droplet "docker cp /tmp/config.user.json ${CONTAINER}:/app/workspace/.openclaw/config.user.json && rm -f /tmp/config.user.json"
                note "  stripped shared-folder fragment from systemPromptOverride"
            fi
        fi
    fi
fi

# ── 4. restart so overlay change takes effect ──────────────────────
note "phase 4/4 — restart ${CONTAINER} (skip with --no-restart)"
if [[ "$NO_RESTART" -eq 0 && "$DRY_RUN" -eq 0 ]]; then
    state=$(run_droplet "docker inspect -f '{{.State.Status}}' ${CONTAINER}" 2>/dev/null || true)
    if [[ "$state" == "running" ]]; then
        run_droplet "docker restart ${CONTAINER}" >/dev/null
    fi
fi

note "✅ deprovisioned ${POD_LABEL}"
