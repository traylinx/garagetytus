#!/usr/bin/env bash
# garagetytus-folder-bind — one-Mac-command setup for shared folders.
#
# Per Q14 verdict: launchd polling-only, NO WatchPaths, timeout-wrapped
# rclone bisync. The brittle WatchPaths plist that v0.5.0 attempted is
# explicitly NOT what this ships.
#
# Usage:
#   garagetytus folder bind <local-path> <bucket> [--to <pod>...]
#                           [--auto-sync] [--interval N] [--timeout N]
#                           [--rclone-conf PATH] [--droplet HOST]
#                           [--no-pod-restart] [--dry-run]
#
# Registry mode (Tytus shared folders on AWS S3, files-handsfree A4):
#   garagetytus folder bind <local-path> <bucket> --registry \
#                           --prefix <storage-prefix> [--remote tytusaws] \
#                           [--auto-sync] [--interval N] [--timeout N]
#   Skips Garage bucket/key minting and pod legs — the registry owns those.
#   Requires a pre-configured rclone remote (default: tytusaws) backed by a
#   scoped IAM user limited to the owner's folder prefixes.
#
# Example (the headline UX):
#   garagetytus folder bind ~/Documents/work testbucket --to 02 --auto-sync
#
#   creates testbucket if absent, mints a Mac-side `mac-<bucket>` Garage
#   key, adds an rclone remote, runs initial bisync --resync, drops a
#   60-second-poll launchd plist, AND provisions tytus-02 with the
#   garagetytus-shared wrapper for the same bucket. One command, full UX.

set -euo pipefail

DROPLET="${GARAGETYTUS_DROPLET:-root@212.227.205.146}"
DROPLET_CONFIG="/var/lib/garagetytus/config/garagetytus.toml"
WANNOLOT_NETNS="wannolot-01"
EXTERNAL_ENDPOINT="${GARAGETYTUS_ENDPOINT:-${GARAGETYTUS_EXTERNAL_ENDPOINT:-http://10.42.42.1:3900}}"
RCLONE_REMOTE="garagetytus"
RCLONE_CONF="${HOME}/.config/rclone/rclone.conf"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROVISION_SCRIPT="${SCRIPT_DIR}/garagetytus-pod-provision"
PLIST_DIR="${HOME}/Library/LaunchAgents"
WORKDIR_BASE="${HOME}/.cache/garagetytus/bisync"
LOG_BASE="/tmp/garagetytus-bisync"

# Default sync hygiene. Shared folders are for user/project files, not generated
# dependency stores. Without this, a "small" folder containing venv/node_modules
# becomes thousands of tiny S3 writes and initial bind looks frozen.
# Set GARAGETYTUS_SYNC_ALL=1 for an explicit full mirror.
DEFAULT_EXCLUDES=(
    ".DS_Store"
    "**/.DS_Store"
    ".git/**"
    "**/.git/**"
    "node_modules/**"
    "**/node_modules/**"
    ".venv/**"
    "**/.venv/**"
    "venv/**"
    "**/venv/**"
    "__pycache__/**"
    "**/__pycache__/**"
    ".pytest_cache/**"
    "**/.pytest_cache/**"
    ".mypy_cache/**"
    "**/.mypy_cache/**"
    ".ruff_cache/**"
    "**/.ruff_cache/**"
    ".cache/**"
    "**/.cache/**"
    ".env"
    ".env.*"
    "**/.env"
    "**/.env.*"
)

LOCAL_PATH=""
BUCKET=""
PODS=()
AUTO_SYNC=0
INTERVAL=60
TIMEOUT_SEC=300
# Initial --resync must never be killed mid-listing: a partial resync leaves an
# inconsistent bisync baseline. Keep this separate from poll timeout.
# Initial --resync can be slow for real client workspaces with thousands of
# small files. 30m was too short for ~/freelance-office and killed rclone before
# it wrote the bisync baseline/sidecar. Keep poll sync bounded separately, but
# give first bind enough room to finish safely.
RESYNC_TIMEOUT_SEC=7200
NO_POD_RESTART=0
DRY_RUN=0
REGISTRY=0
PREFIX=""

err() { printf 'folder-bind: %s\n' "$*" >&2; exit 1; }
note() { printf 'folder-bind: %s\n' "$*" >&2; }
usage() { sed -n '1,30p' "$0" | sed 's|^# \{0,1\}||'; }

# Parse `bind` as the first positional if invoked via the
# `garagetytus folder bind` form (Phase D shape).
if [[ "${1:-}" == "folder" && "${2:-}" == "bind" ]]; then shift 2; fi
if [[ "${1:-}" == "bind" ]]; then shift; fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --to)               PODS+=("$2"); shift 2;;
        --auto-sync)        AUTO_SYNC=1; shift;;
        --interval)         INTERVAL="$2"; shift 2;;
        --timeout)          TIMEOUT_SEC="$2"; shift 2;;
        --rclone-conf)      RCLONE_CONF="$2"; shift 2;;
        --droplet)          DROPLET="$2"; shift 2;;
        --no-pod-restart)   NO_POD_RESTART=1; shift;;
        --registry)         REGISTRY=1; shift;;
        --prefix)           PREFIX="$2"; shift 2;;
        --remote)           RCLONE_REMOTE="$2"; shift 2;;
        --dry-run)          DRY_RUN=1; shift;;
        -h|--help)          usage; exit 0;;
        --) shift; break;;
        -*) err "unknown flag: $1 (try --help)";;
        *)
            if   [[ -z "$LOCAL_PATH" ]]; then LOCAL_PATH="$1"
            elif [[ -z "$BUCKET" ]];     then BUCKET="$1"
            else err "unexpected positional: $1"; fi
            shift;;
    esac
done

[[ -n "$LOCAL_PATH" ]] || err "missing <local-path> (try --help)"
[[ -n "$BUCKET" ]]     || err "missing <bucket> (try --help)"
if [[ "$REGISTRY" -eq 1 ]]; then
    [[ -n "$PREFIX" ]] || err "--registry requires --prefix <storage-prefix>"
    [[ "${#PODS[@]}" -eq 0 ]] || err "--registry binds the Mac leg only; pods get creds from the registry (drop --to)"
    # prefix sanity: no leading slash, no traversal
    [[ "$PREFIX" != /* && "$PREFIX" != *..* ]] || err "invalid --prefix '${PREFIX}'"
    [[ "$RCLONE_REMOTE" == "garagetytus" ]] && RCLONE_REMOTE="tytusaws"
fi

# Validate bucket name shape (Garage rules: 3-63, lowercase alnum/dot/hyphen,
# alnum endpoints).
if ! [[ "$BUCKET" =~ ^[a-z0-9]([a-z0-9.-]{1,61}[a-z0-9])?$ ]]; then
    err "bucket name '${BUCKET}' violates Garage naming rules"
fi

# Resolve LOCAL_PATH to absolute path
case "$LOCAL_PATH" in
    /*) ;;
    ~*) LOCAL_PATH="${LOCAL_PATH/#\~/$HOME}";;
    *)  LOCAL_PATH="$(pwd)/${LOCAL_PATH}";;
esac

SAFE_NAME=$(printf '%s' "$BUCKET-$(basename "$LOCAL_PATH")" \
    | tr '[:upper:]' '[:lower:]' \
    | sed 's/[^a-z0-9.-]/-/g')
SLUG=$(python3 - "$LOCAL_PATH" "$BUCKET" <<'PY'
import os, re, sys
base = os.path.basename(os.path.normpath(sys.argv[1])) or sys.argv[2]
slug = re.sub(r"[^a-z0-9-]+", "-", base.lower()).strip("-")
if not slug or len(slug) > 63:
    slug = re.sub(r"[^a-z0-9-]+", "-", sys.argv[2].lower()).strip("-")[:63]
print(slug or "shared")
PY
)
FOLDER_ID="sf_$(printf '%s' "${BUCKET}|${LOCAL_PATH}" | shasum -a 256 | awk '{print substr($1,1,16)}')"
if [[ "$REGISTRY" -eq 1 ]]; then
    REMOTE_PATH="${RCLONE_REMOTE}:${BUCKET}/${PREFIX%/}"
    # registry-<dir> label: same folder name bound via garage AND registry
    # must not collide on plist/workdir names.
    SAFE_NAME=$(printf '%s' "registry-$(basename "$LOCAL_PATH")" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9.-]/-/g')
else
    REMOTE_PATH="${RCLONE_REMOTE}:${BUCKET}"
fi

PLIST_LABEL="com.traylinx.garagetytus.bisync.${SAFE_NAME}"
PLIST_PATH="${PLIST_DIR}/${PLIST_LABEL}.plist"
WORKDIR="${WORKDIR_BASE}/${SAFE_NAME}"
LOG_OUT="${LOG_BASE}-${SAFE_NAME}.log"
LOG_ERR="${LOG_BASE}-${SAFE_NAME}.err"
SIDECAR="${WORKDIR_BASE}/${SAFE_NAME}.bindings.json"

note "target local=${LOCAL_PATH} bucket=${BUCKET}"
[[ "${#PODS[@]}" -gt 0 ]] && note "target pods=${PODS[*]}"
[[ "$AUTO_SYNC" -eq 1 ]] && note "auto-sync ON (interval=${INTERVAL}s, timeout=${TIMEOUT_SEC}s)"
[[ "$DRY_RUN"   -eq 1 ]] && note "DRY-RUN — no remote/local changes"

unload_existing_auto_sync() {
    [[ "$AUTO_SYNC" -eq 1 && "$DRY_RUN" -eq 0 ]] || return 0
    [[ -f "$PLIST_PATH" ]] || return 0
    note "  unloading existing launchd job before initial resync"
    launchctl unload "$PLIST_PATH" 2>/dev/null || true
}

write_binding_sidecar() {
    local state="$1"; shift || true
    [[ "$DRY_RUN" -eq 0 ]] || return 0
    mkdir -p "$WORKDIR_BASE"
    local bound_at pods_json status_json targets_json tmp sync_state sync_phase
    bound_at=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    sync_state="${SYNC_STATE:-pending}"
    sync_phase="${SYNC_PHASE:-initial_resync}"

    if [[ "$#" -gt 0 ]]; then
        pods_json=$(printf '%s\n' "$@" | jq -R '
            def selector: if test("^(wannolot|tytus)-") then sub("^(wannolot|tytus)-"; "") else . end;
            select(length > 0)
            | selector as $sel
            | if ($sel | test("^[0-9]+$")) then "wannolot-" + $sel else $sel end
        ' | jq -s .)
        status_json=$(printf '%s\n' "$@" | jq -R --arg slug "$SLUG" --arg state "$state" '
            def selector: if test("^(wannolot|tytus)-") then sub("^(wannolot|tytus)-"; "") else . end;
            select(length > 0)
            | selector as $rid
            | {key: $rid, value: {
                state: $state,
                workspace_path: ("/app/workspace/shared/" + $slug),
                helper_mode: "legacy_bucket_root",
                last_materialized_at: (if $state == "materialized" then (now | todateiso8601) else null end),
                last_error: null
              }}
        ' | jq -s 'from_entries')
        targets_json=$(printf '%s\n' "$@" | jq -R '
            def selector: if test("^(wannolot|tytus)-") then sub("^(wannolot|tytus)-"; "") else . end;
            select(length > 0)
            | selector as $sel
            | {
                runtime_id: $sel,
                route_id: (if ($sel | test("^[0-9]+$")) then null else $sel end),
                provision_selector: $sel,
                kind: "agent-runtime",
                labels: [],
                enabled: true
              }
        ' | jq -s .)
    else
        pods_json='[]'
        status_json='{}'
        targets_json='[]'
    fi

    tmp="${SIDECAR}.tmp.$$"
    jq -n \
        --arg bucket "$BUCKET" \
        --arg local "$LOCAL_PATH" \
        --arg slug "$SLUG" \
        --arg folder_id "$FOLDER_ID" \
        --arg ts "$bound_at" \
        --argjson pods "$pods_json" \
        --argjson targets "$targets_json" \
        --argjson runtime_status "$status_json" \
        --argjson interval "${INTERVAL}" \
        --argjson auto "$AUTO_SYNC" \
        --arg label "$PLIST_LABEL" \
        --arg workdir "$WORKDIR" \
        --arg remote "$RCLONE_REMOTE" \
        --arg remote_path "${REMOTE_PATH#${RCLONE_REMOTE}:}" \
        --arg sync_state "$sync_state" \
        --arg sync_phase "$sync_phase" \
        '{schema_version:2, bound_at:$ts, folder_id:$folder_id, slug:$slug,
          bucket:$bucket, sync_layout:"legacy_bucket_root",
          remote:$remote, remote_path:$remote_path,
          local_path:$local, pods_provisioned:$pods,
          targets:$targets, runtime_status:$runtime_status,
          sync_status:{state:$sync_state, phase:$sync_phase, checked_at:$ts, baseline_ready:false},
          auto_sync:($auto==1), interval_sec:$interval,
          plist_label:$label, workdir:$workdir}' \
        > "$tmp"
    mv "$tmp" "$SIDECAR"
}

install_auto_sync_plist() {
    if [[ "$AUTO_SYNC" -eq 1 ]]; then
        note "  install launchd plist (StartInterval=${INTERVAL}, timeout=${TIMEOUT_SEC})"
        if [[ "$DRY_RUN" -eq 0 ]]; then
            mkdir -p "$PLIST_DIR"
            # Per Q14 Option 1: NO WatchPaths, NO KeepAlive. Just polling
            # interval + bounded timeout per run. Install only after sidecar
            # exists, so background sync cannot race the bind/provision job.
            cat > "$PLIST_PATH" <<PLEOF
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>${PLIST_LABEL}</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/garagetytus-folder-sync</string>
    <string>--rclone-conf</string>
    <string>${RCLONE_CONF}</string>
    <string>--remote</string>
    <string>${RCLONE_REMOTE}</string>
    <string>--remote-path</string>
    <string>${REMOTE_PATH#${RCLONE_REMOTE}:}</string>
    <string>--workdir</string>
    <string>${WORKDIR}</string>
    <string>--timeout</string>
    <string>${TIMEOUT_SEC}</string>
    <string>--resync-timeout</string>
    <string>${RESYNC_TIMEOUT_SEC}</string>
    <string>${LOCAL_PATH}</string>
    <string>${BUCKET}</string>
  </array>
  <key>StartInterval</key>
  <integer>${INTERVAL}</integer>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>${LOG_OUT}</string>
  <key>StandardErrorPath</key>
  <string>${LOG_ERR}</string>
  <key>ProcessType</key>
  <string>Background</string>
</dict>
</plist>
PLEOF
            launchctl unload "$PLIST_PATH" 2>/dev/null || true
            launchctl load "$PLIST_PATH"
            note "  launchd job ${PLIST_LABEL} loaded"
        fi
    else
        note "phase 7/7 — skipped (no --auto-sync; one-shot bisync only)"
    fi
}

canonical_local_path() {
    python3 - "$1" <<'PY'
import os, sys
p = os.path.abspath(os.path.expanduser(sys.argv[1]))
real = os.path.realpath(p)
if real != os.sep:
    real = real.rstrip(os.sep)
print(os.path.normcase(real))
PY
}

path_relation() {
    python3 - "$1" "$2" <<'PY'
import os, sys
a = os.path.normcase(os.path.realpath(os.path.abspath(sys.argv[1]))).rstrip(os.sep) or os.sep
b = os.path.normcase(os.path.realpath(os.path.abspath(sys.argv[2]))).rstrip(os.sep) or os.sep
if a == b:
    print("same")
elif os.path.commonpath([a, b]) == a:
    print("a_contains_b")
elif os.path.commonpath([a, b]) == b:
    print("b_contains_a")
else:
    print("none")
PY
}

check_existing_binding_conflicts() {
    [[ "$DRY_RUN" -eq 0 ]] || return 0
    mkdir -p "$WORKDIR_BASE"
    local requested_real
    requested_real="$(canonical_local_path "$LOCAL_PATH")"

    shopt -s nullglob
    local sidecars=("${WORKDIR_BASE}"/*.bindings.json)
    shopt -u nullglob
    for sidecar in "${sidecars[@]}"; do
        local existing_bucket existing_local existing_real rel
        existing_bucket="$(jq -r '.bucket // empty' "$sidecar" 2>/dev/null || true)"
        existing_local="$(jq -r '.local_path // empty' "$sidecar" 2>/dev/null || true)"
        [[ -n "$existing_bucket" && -n "$existing_local" ]] || continue

        existing_real="$(canonical_local_path "$existing_local")"

        if [[ "$existing_bucket" == "$BUCKET" && "$existing_real" == "$requested_real" ]]; then
            err "bucket '${BUCKET}' is already bound to ${existing_local}; open that folder's settings instead of creating it again"
        fi
        if [[ "$existing_bucket" == "$BUCKET" ]]; then
            err "bucket '${BUCKET}' is already bound to ${existing_local}; choose a new bucket name or unbind the existing folder first"
        fi

        rel="$(path_relation "$LOCAL_PATH" "$existing_local")"
        case "$rel" in
            same)
                err "local folder ${LOCAL_PATH} is already bound to bucket '${existing_bucket}'; choose a different folder or unbind the existing binding first"
                ;;
            a_contains_b)
                err "local folder ${LOCAL_PATH} contains existing binding ${existing_local} (bucket '${existing_bucket}'); shared folders cannot be nested"
                ;;
            b_contains_a)
                err "local folder ${LOCAL_PATH} is inside existing binding ${existing_local} (bucket '${existing_bucket}'); shared folders cannot be nested"
                ;;
        esac
    done
}

check_existing_binding_conflicts

run_droplet() {
    if [[ "$DRY_RUN" -eq 1 ]]; then
        printf 'DRY: ssh %s %s\n' "$DROPLET" "$*" >&2; return 0
    fi
    ssh -o BatchMode=yes "$DROPLET" "$@"
}
run_garage() {
    run_droplet "WPID=\$(docker inspect -f '{{.State.Pid}}' ${WANNOLOT_NETNS}) && \
                 nsenter -t \$WPID -n -- /root/.local/bin/garage -c ${DROPLET_CONFIG} $*"
}

ensure_rclone_endpoint() {
    [[ "$DRY_RUN" -eq 0 ]] || return 0
    [[ -f "$RCLONE_CONF" ]] || return 0
    tmp="${RCLONE_CONF}.endpoint.$$"
    awk -v r="[${RCLONE_REMOTE}]" -v endpoint="${EXTERNAL_ENDPOINT}" '
        $0 == r { in_block=1; saw_endpoint=0; print; next }
        in_block && /^\[/ {
            if (!saw_endpoint) print "endpoint = " endpoint
            in_block=0
        }
        in_block && /^endpoint[[:space:]]*=/ {
            print "endpoint = " endpoint
            saw_endpoint=1
            next
        }
        { print }
        END {
            if (in_block && !saw_endpoint) print "endpoint = " endpoint
        }
    ' "$RCLONE_CONF" > "$tmp"
    mv "$tmp" "$RCLONE_CONF"
    chmod 600 "$RCLONE_CONF"
}

# Registry mode: the AWS bucket, scoped IAM creds, and pod provisioning
# are owned by the Tytus registry — only the Mac bisync legs apply here.
if [[ "$REGISTRY" -eq 0 ]]; then
# ── 1. ensure bucket exists on droplet ─────────────────────────────
note "phase 1/6 — ensure bucket exists"
if [[ "$DRY_RUN" -eq 0 ]]; then
    if run_garage "bucket info ${BUCKET}" >/dev/null 2>&1; then
        note "  bucket ${BUCKET} already exists"
    else
        run_garage "bucket create ${BUCKET}" >/dev/null
        note "  bucket ${BUCKET} created"
    fi
fi

# ── 2-3. ensure Mac-side key + rclone remote can reach this bucket ─
note "phase 2/6 — ensure Mac key + rclone remote can reach ${BUCKET}"
existing_ak=""
if [[ -f "$RCLONE_CONF" ]]; then
    # Extract access_key_id from existing [garagetytus] remote (if present).
    existing_ak=$(awk -v r="[${RCLONE_REMOTE}]" '
        $0 == r { in_block=1; next }
        /^\[/   { in_block=0 }
        in_block && /^access_key_id/ {
            sub(/^access_key_id[[:space:]]*=[[:space:]]*/, "")
            print; exit
        }' "$RCLONE_CONF")
fi

if [[ -n "$existing_ak" ]]; then
    # Reuse the existing remote's key: just add bucket allow on the droplet.
    note "  reusing existing rclone remote key id=${existing_ak}"
    if [[ "$DRY_RUN" -eq 0 ]]; then
        run_garage "bucket allow --read --write ${BUCKET} --key ${existing_ak}" >/dev/null
    fi
else
    # No existing remote — mint a fresh `mac-shared` key with rw on this
    # bucket and write a new rclone remote section. Future bind calls
    # detect this key and just add more bucket allows to it.
    mac_key_name="mac-shared"
    if [[ "$DRY_RUN" -eq 1 ]]; then
        ak="GKDRYRUNMAC"; sk="DRYRUN"
    else
        # If the key already exists from a previous bind: rotate (delete +
        # recreate) so we know the secret_key for the rclone remote write.
        prev_id=$(run_garage "key list" 2>/dev/null \
            | awk -v n="$mac_key_name" '$3==n {print $1; exit}')
        [[ -n "$prev_id" ]] && run_garage "key delete --yes ${prev_id}" >/dev/null
        create_out=$(run_garage "key create ${mac_key_name}")
        ak=$(printf '%s\n' "$create_out" | awk -F': *' '/^Key ID/{print $2; exit}')
        sk=$(printf '%s\n' "$create_out" | awk -F': *' '/^Secret key/{print $2; exit}')
        [[ -n "$ak" && -n "$sk" ]] || err "failed to parse key from create output"
        run_garage "bucket allow --read --write ${BUCKET} --key ${ak}" >/dev/null
    fi
    note "  minted ${mac_key_name} (id=${ak}); writing rclone remote"

    if [[ "$DRY_RUN" -eq 0 ]]; then
        mkdir -p "$(dirname "$RCLONE_CONF")"
        if [[ -f "$RCLONE_CONF" ]]; then
            cp "$RCLONE_CONF" "${RCLONE_CONF}.bak.$(date -u +%Y%m%dT%H%M%SZ)"
            cat "$RCLONE_CONF" > "${RCLONE_CONF}.new"
            printf '\n' >> "${RCLONE_CONF}.new"
        else
            : > "${RCLONE_CONF}.new"
        fi
        cat >> "${RCLONE_CONF}.new" <<RCEOF
[${RCLONE_REMOTE}]
type = s3
provider = Other
access_key_id = ${ak}
secret_access_key = ${sk}
endpoint = ${EXTERNAL_ENDPOINT}
region = garage
RCEOF
        mv "${RCLONE_CONF}.new" "$RCLONE_CONF"
        chmod 600 "$RCLONE_CONF"
    fi
fi

ensure_rclone_endpoint
note "phase 3/6 — bucket-allow confirmed for ${BUCKET}"

# ── 4. mkdir local path + initial bisync --resync ─────────────────
else
    note "phase 1-3/6 — skipped (--registry: bucket/keys owned by the registry)"
    if [[ "$DRY_RUN" -eq 0 ]]; then
        # List the folder PREFIX, not the bucket root: the scoped IAM user is
        # prefix-conditioned and bucket-root listing is (correctly) denied.
        rclone --config "$RCLONE_CONF" lsf "${REMOTE_PATH}/" --max-depth 1 >/dev/null 2>&1 \
            || err "rclone remote '${RCLONE_REMOTE}' cannot reach ${REMOTE_PATH} — configure it first (scoped IAM user)"
        note "  remote ${RCLONE_REMOTE} reaches ${REMOTE_PATH} OK"
    fi
fi

note "phase 4/7 — register binding + prepare background sync"
mkdir -p "$LOCAL_PATH" "$WORKDIR"
unload_existing_auto_sync
# rclone bisync's safety check refuses to sync if the prior path1
# listing is empty ("Empty prior Path1 listing"). An empty initial
# --resync poisons subsequent runs. Drop a sentinel file BEFORE any
# initial sync so path1.lst always has at least one entry.
MARKER_FILE="${LOCAL_PATH}/.garagetytus-bound"
if [[ ! -f "$MARKER_FILE" ]]; then
    cat > "$MARKER_FILE" <<MEOF
This folder is bound to s3://${BUCKET} via garagetytus.
Bound at: $(date -u +%Y-%m-%dT%H:%M:%SZ)
Bound by: $(whoami)@$(hostname -s)
Do not delete this marker — bisync uses it to track folder identity.
MEOF
fi

# Bind registration must be fast. The shared-folders view can show "Syncing…"
# while launchd/rclone performs the expensive initial --resync in the background.
SYNC_STATE="syncing" SYNC_PHASE="initial_resync" write_binding_sidecar "provisioning" "${PODS[@]}"

if [[ "$AUTO_SYNC" -eq 1 ]]; then
    note "phase 5/7 — start background initial sync"
    install_auto_sync_plist
else
    note "phase 5/7 — initial bisync --resync (foreground; --auto-sync disabled)"
    if [[ "$DRY_RUN" -eq 0 ]]; then
        /usr/local/bin/garagetytus-folder-sync \
            --rclone-conf "$RCLONE_CONF" \
            --remote "$RCLONE_REMOTE" \
            --remote-path "${REMOTE_PATH#${RCLONE_REMOTE}:}" \
            --workdir "$WORKDIR" \
            --timeout "$TIMEOUT_SEC" \
            --resync-timeout "$RESYNC_TIMEOUT_SEC" \
            "$LOCAL_PATH" "$BUCKET" 2>&1 | sed 's/^/    /' || \
            err "initial bisync --resync failed"
        note "  initial sync complete: ${LOCAL_PATH} ↔ ${REMOTE_PATH}"
    fi
    SYNC_STATE="synced" SYNC_PHASE="idle" write_binding_sidecar "provisioning" "${PODS[@]}"
fi

# ── 6. (optional) provision named pods, in parallel ───────────────
declare -a provisioned_pods=()
if [[ "${#PODS[@]}" -gt 0 ]]; then
    note "phase 6/7 — provision pods (parallel): ${PODS[*]}"
    [[ -x "$PROVISION_SCRIPT" ]] || err "missing ${PROVISION_SCRIPT}"

    if [[ "$DRY_RUN" -eq 1 ]]; then
        for pod in "${PODS[@]}"; do
            note "  DRY: would call ${PROVISION_SCRIPT} ${pod} --bucket ${BUCKET}"
        done
        for pod in "${PODS[@]}"; do
            provisioned_pods+=("$pod")
        done
    else
        # Launch every pod-provision in background, capture log + pid.
        declare -A pod_pids pod_logs
        extra=()
        [[ "$NO_POD_RESTART" -eq 1 ]] && extra+=(--no-restart)
        for pod in "${PODS[@]}"; do
            log=$(mktemp -t "garagetytus-prov-${pod}-XXXXXX")
            pod_logs[$pod]="$log"
            "$PROVISION_SCRIPT" "$pod" --bucket "$BUCKET" \
                --slug "$SLUG" --folder-id "$FOLDER_ID" \
                --droplet "$DROPLET" "${extra[@]}" >"$log" 2>&1 &
            pod_pids[$pod]=$!
            note "  launched provision for ${pod} (pid=${pod_pids[$pod]})"
        done
        # Wait + collect outcomes; print each pod's full log under a prefix
        declare -a failed_pods=()
        for pod in "${PODS[@]}"; do
            if wait "${pod_pids[$pod]}"; then
                provisioned_pods+=("$pod")
            else
                failed_pods+=("$pod")
            fi
            sed "s/^/    [pod-${pod}] /" "${pod_logs[$pod]}" >&2
            rm -f "${pod_logs[$pod]}"
        done
        [[ "${#failed_pods[@]}" -gt 0 ]] && err "pod-provision failed for: ${failed_pods[*]}"
    fi
else
    note "phase 6/7 — skipped (no --to pods)"
fi

# ── 7. finalize sidecar ────────────────────────────────────────────
note "phase 7/7 — finalize binding sidecar"
if [[ "$AUTO_SYNC" -eq 1 ]]; then
    SYNC_STATE="syncing" SYNC_PHASE="initial_resync" write_binding_sidecar "materialized" "${provisioned_pods[@]}"
else
    SYNC_STATE="synced" SYNC_PHASE="idle" write_binding_sidecar "materialized" "${provisioned_pods[@]}"
fi

note "✅ folder-bind complete: ${LOCAL_PATH} ↔ ${REMOTE_PATH} (file sync continues in background when auto-sync is enabled)"
