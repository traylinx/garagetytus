#!/usr/bin/env bash
# garagetytus-folder-list — show every Mac↔bucket binding registered
# by `garagetytus folder bind`. Read-only; safe to run anytime.
#
# Usage:
#   garagetytus folder list [--json] [--launch-agent-dir DIR]
#
# Source of truth: every plist matching
# `${HOME}/Library/LaunchAgents/com.traylinx.garagetytus.bisync.*.plist`.
# Local path + bucket name come from parsing the plist's
# ProgramArguments. Last-sync time = mtime of the log file at
# `/tmp/garagetytus-bisync-<safe-name>.log`. Job state from
# `launchctl list`.

set -euo pipefail

PLIST_DIR="${HOME}/Library/LaunchAgents"
JSON=0

err() { printf 'folder-list: %s\n' "$*" >&2; exit 1; }
usage() { sed -n '1,15p' "$0" | sed 's|^# \{0,1\}||'; }

# Accept `garagetytus folder list` invocation form too.
if [[ "${1:-}" == "folder" && "${2:-}" == "list" ]]; then shift 2; fi
if [[ "${1:-}" == "list" ]]; then shift; fi

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json)              JSON=1; shift;;
        --launch-agent-dir)  PLIST_DIR="$2"; shift 2;;
        -h|--help)           usage; exit 0;;
        *) err "unknown flag: $1 (try --help)";;
    esac
done

WORKDIR_BASE="${HOME}/.cache/garagetytus/bisync"

shopt -s nullglob
plists=("${PLIST_DIR}"/com.traylinx.garagetytus.bisync.*.plist)
sidecars=("${WORKDIR_BASE}"/*.bindings.json)
shopt -u nullglob

if [[ "${#plists[@]}" -eq 0 && "${#sidecars[@]}" -eq 0 ]]; then
    if [[ "$JSON" -eq 1 ]]; then echo '[]'
    else echo "(no folder bindings registered)" >&2; fi
    exit 0
fi

# Build a single launchctl-list cache once
launchctl_cache=$(launchctl list 2>/dev/null \
    | awk '$3 ~ /^com\.traylinx\.garagetytus\.bisync\./ {print $1" "$2" "$3}')

probe_label() {
    local label="$1"
    printf '%s\n' "$launchctl_cache" \
        | awk -v L="$label" '$3==L {print $1" "$2; exit}'
}

# Build a deduped row set from BOTH plists (auto-sync bindings) and
# sidecar JSONs (every binding since v0.5.3, including non-auto-sync).
# Without the sidecar pass, bindings made via `folder bind <path>
# <bucket>` (no --auto-sync) would be invisible to this command —
# fixed in v0.5.4 alongside the matching unbind fix.
declare -a rows=()
declare -A seen_safe=()

# Pass 1: plists (covers --auto-sync bindings; reads the live
# launchctl state + log mtime).
for plist in "${plists[@]}"; do
    label=$(basename "$plist" .plist)
    safe_name="${label#com.traylinx.garagetytus.bisync.}"
    args=$(plutil -convert json -o - "$plist" 2>/dev/null \
        | jq -r '.ProgramArguments[3] // ""')
    [[ -z "$args" ]] && continue
    seen_safe[$safe_name]=1

    # Args looks like:
    # /usr/local/bin/timeout 45 /usr/local/bin/rclone --config "..." bisync "<LOCAL>" "garagetytus:<BUCKET>" --workdir ...
    local_path=$(printf '%s' "$args" \
        | sed -nE 's/.*bisync "([^"]+)" "[a-z0-9_-]+:[^"]+".*/\1/p')
    bucket=$(printf '%s' "$args" \
        | sed -nE 's/.*bisync "[^"]+" "[a-z0-9_-]+:([^"]+)".*/\1/p')
    interval=$(plutil -convert json -o - "$plist" 2>/dev/null \
        | jq -r '.StartInterval // "?"')

    log="/tmp/garagetytus-bisync-${safe_name}.log"
    err_log="/tmp/garagetytus-bisync-${safe_name}.err"
    if [[ -f "$err_log" ]]; then
        mtime=$(stat -f '%Sm' -t '%Y-%m-%dT%H:%M:%SZ' "$err_log" 2>/dev/null || echo "?")
        last_sync_epoch=$(stat -f '%m' "$err_log" 2>/dev/null || echo 0)
    else
        mtime="never"
        last_sync_epoch=0
    fi
    if [[ "$last_sync_epoch" -gt 0 ]]; then
        age_sec=$(( $(date +%s) - last_sync_epoch ))
        if   [[ $age_sec -lt 120 ]];  then age="${age_sec}s ago"
        elif [[ $age_sec -lt 3600 ]]; then age="$(( age_sec / 60 ))m ago"
        elif [[ $age_sec -lt 86400 ]]; then age="$(( age_sec / 3600 ))h ago"
        else age="$(( age_sec / 86400 ))d ago"; fi
    else
        age="never"
    fi

    probe=$(probe_label "$label")
    if [[ -z "$probe" ]]; then
        state="not loaded"
    else
        pid="${probe%% *}"
        exit_code="${probe##* }"
        if   [[ "$pid" =~ ^[0-9]+$ && "$pid" -gt 0 ]]; then
            state="running pid=${pid}"
        elif [[ "$exit_code" == "0" ]]; then
            state="idle"
        else
            state="exit=${exit_code}"
        fi
    fi

    rows+=("$(jq -nc \
        --arg bucket "$bucket" \
        --arg local "$local_path" \
        --arg label "$label" \
        --arg state "$state" \
        --arg interval "$interval" \
        --arg last_sync "$mtime" \
        --arg age "$age" \
        '{bucket:$bucket, local_path:$local, label:$label,
          state:$state, interval_sec:($interval|tonumber? // 0),
          last_sync:$last_sync, last_sync_age:$age}')")
done

# Pass 2: sidecars not already covered by Pass 1 (non-auto-sync binds).
# State = "no auto-sync" (no plist, no launchctl entry, no log mtime).
for sidecar in "${sidecars[@]}"; do
    sname=$(basename "$sidecar" .bindings.json)
    [[ -n "${seen_safe[$sname]:-}" ]] && continue
    bucket=$(jq -r '.bucket // ""' "$sidecar" 2>/dev/null)
    local_path=$(jq -r '.local_path // ""' "$sidecar" 2>/dev/null)
    [[ -z "$bucket" || -z "$local_path" ]] && continue
    label="(sidecar-only)"
    state="no auto-sync"
    interval=0
    mtime="never"
    age="never"
    rows+=("$(jq -nc \
        --arg bucket "$bucket" \
        --arg local "$local_path" \
        --arg label "$label" \
        --arg state "$state" \
        --arg interval "$interval" \
        --arg last_sync "$mtime" \
        --arg age "$age" \
        '{bucket:$bucket, local_path:$local, label:$label,
          state:$state, interval_sec:($interval|tonumber? // 0),
          last_sync:$last_sync, last_sync_age:$age}')")
done

if [[ "$JSON" -eq 1 ]]; then
    printf '%s\n' "${rows[@]}" | jq -s '.'
    exit 0
fi

printf '%-30s %-50s %-18s %s\n' "BUCKET" "LOCAL" "STATE" "LAST SYNC"
printf '%-30s %-50s %-18s %s\n' "------" "-----" "-----" "---------"
for row in "${rows[@]}"; do
    printf '%-30s %-50s %-18s %s\n' \
        "$(printf '%s' "$row" | jq -r '.bucket')" \
        "$(printf '%s' "$row" | jq -r '.local_path')" \
        "$(printf '%s' "$row" | jq -r '.state')" \
        "$(printf '%s' "$row" | jq -r '.last_sync_age')"
done
