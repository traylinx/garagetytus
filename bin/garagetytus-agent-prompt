#!/usr/bin/env bash
# garagetytus-agent-prompt — emit a paste-ready agent chat prompt
# for a granted bucket on a remote garagetytus daemon.
#
# ⚠️  v0.5.1 NOTE: This is the break-glass / manual override path.
# The default path is now `garagetytus folder bind --to <pod>`
# which provisions credentials INTO the pod (no chat-paste). Use
# this script only when:
#   - bootstrapping a fresh agent runtime that doesn't know about
#     `garagetytus-shared`
#   - debugging `garagetytus-pod-provision` failures
#   - integrating a non-tytus environment (Linux laptop, second
#     Mac) where the pod-provision script doesn't apply
#
# Pastes into Claude Code / ChatGPT / OpenClaw / Hermes / etc.
# running inside (or alongside) a tytus pod, so the agent knows
# what bucket it has access to, what its identity is, what
# endpoint to use, and how to PUT/GET/LIST without further setup.
#
# Usage:
#   garagetytus-agent-prompt --bucket <name> --pod <pod-id> [options]
#
# Options:
#   --bucket NAME        bucket name, e.g. "work" or "shared"             [required]
#   --pod ID             pod identity, e.g. "wannolot-02"                 [required]
#   --style boto3|aws-cli|both
#                        which client recipes to embed in the prompt.
#                        Default: boto3 (empirically what tytus pods have).
#                        Use aws-cli for Mac-side agents or pod images that
#                        ship awscli. "both" emits both for max flexibility.
#   --droplet HOST       SSH host for `garagetytus bucket grant` lookup
#                        (default: env GARAGETYTUS_DROPLET, else fail)
#   --endpoint URL       S3 endpoint exposed to the pod
#                        (default: http://10.42.42.1:3900)
#   --access-key K       skip SSH grant call, use these creds verbatim
#   --secret-key S       skip SSH grant call, use these creds verbatim
#   --ttl DURATION       passed to bucket grant (default: 30d)
#   --copy               also pipe to pbcopy (macOS) or xclip (Linux)
#   --no-grant           don't fetch new creds; require --access-key + --secret-key
#   -h, --help           show this help and exit
#
# When --access-key + --secret-key are NOT given and --no-grant
# is NOT set, the script SSHes to the droplet and runs:
#
#   garagetytus bucket grant <bucket> --to <pod> --perms read,write \
#       --ttl <ttl> --json
#
# parsing the JSON for `access_key` and `secret_key`. This issues
# a NEW grant — every invocation creates a new keypair. To reuse
# an existing keypair, pass --access-key + --secret-key + --no-grant.

set -euo pipefail

BUCKET=""
POD=""
STYLE="boto3"
DROPLET="${GARAGETYTUS_DROPLET:-}"
ENDPOINT="http://10.42.42.1:3900"
ACCESS_KEY=""
SECRET_KEY=""
TTL="30d"
COPY=0
NO_GRANT=0

err() { printf 'garagetytus-agent-prompt: %s\n' "$*" >&2; exit 1; }
usage() { sed -n '1,45p' "$0" | sed 's|^# \{0,1\}||'; }

while [[ $# -gt 0 ]]; do
    case "$1" in
        --bucket)     BUCKET="$2";     shift 2;;
        --pod)        POD="$2";        shift 2;;
        --style)      STYLE="$2";      shift 2;;
        --droplet)    DROPLET="$2";    shift 2;;
        --endpoint)   ENDPOINT="$2";   shift 2;;
        --access-key) ACCESS_KEY="$2"; shift 2;;
        --secret-key) SECRET_KEY="$2"; shift 2;;
        --ttl)        TTL="$2";        shift 2;;
        --copy)       COPY=1;          shift;;
        --no-grant)   NO_GRANT=1;      shift;;
        -h|--help)    usage; exit 0;;
        *)            err "unknown flag: $1 (try --help)";;
    esac
done

case "$STYLE" in
    boto3|aws-cli|both) ;;
    *) err "--style must be boto3 | aws-cli | both (got: $STYLE)";;
esac

[[ -z "$BUCKET" ]] && err "--bucket is required"
[[ -z "$POD" ]]    && err "--pod is required"

if [[ -z "$ACCESS_KEY" || -z "$SECRET_KEY" ]]; then
    if [[ "$NO_GRANT" -eq 1 ]]; then
        err "--no-grant given but --access-key and --secret-key not provided"
    fi
    [[ -z "$DROPLET" ]] && err "--droplet HOST or env GARAGETYTUS_DROPLET required when not passing --access-key/--secret-key"

    command -v jq >/dev/null 2>&1 || err "jq is required to parse the grant JSON (brew install jq)"

    json="$(ssh -o ConnectTimeout=5 "$DROPLET" \
        "garagetytus bucket grant '$BUCKET' --to '$POD' --perms read,write --ttl '$TTL' --json" 2>/dev/null)" || \
        err "remote 'garagetytus bucket grant' failed on $DROPLET (run with --no-grant + --access-key/--secret-key to skip)"

    ACCESS_KEY="$(printf '%s' "$json" | jq -r '.access_key // empty')"
    SECRET_KEY="$(printf '%s' "$json" | jq -r '.secret_key // empty')"
    REMOTE_ENDPOINT="$(printf '%s' "$json" | jq -r '.endpoint_url // empty')"

    [[ -z "$ACCESS_KEY" || -z "$SECRET_KEY" ]] && err "grant JSON did not contain access_key/secret_key — got: $json"

    # Honor remote's endpoint_url only if user didn't pass --endpoint
    if [[ "$ENDPOINT" == "http://10.42.42.1:3900" && -n "$REMOTE_ENDPOINT" ]]; then
        :  # keep the WG-routable address; remote endpoint may be loopback
    fi
fi

# Build the prompt body for each style; concatenate per --style.
header="$(cat <<EOF
You have access to a shared file system through a Garage S3
bucket on Sebastian's droplet. Use this when you need to save
a file Sebastian (or another pod) will see, or read a file
they've added for you.

ENDPOINT:    $ENDPOINT
BUCKET:      $BUCKET
YOUR ID:     $POD
ACCESS KEY:  $ACCESS_KEY
SECRET KEY:  $SECRET_KEY
REGION:      garage
EOF
)"

boto3_block="$(cat <<EOF
NOTE: This pod has boto3 (Python) installed but NOT the aws CLI.
Use the Python recipes below — do not invent aws-cli commands.

# How to PUT a file (Sebastian or other pods will see it):
python3 - <<'PY'
import boto3
from botocore.config import Config
s3 = boto3.client("s3",
    endpoint_url="$ENDPOINT",
    aws_access_key_id="$ACCESS_KEY",
    aws_secret_access_key="$SECRET_KEY",
    region_name="garage", config=Config(s3={"addressing_style": "path"}))
with open("./your-file.md", "rb") as f:
    s3.put_object(Bucket="$BUCKET",
                  Key="from-$POD/your-file.md",
                  Body=f.read())
print("OK")
PY

# How to LIST what's in the bucket:
python3 - <<'PY'
import boto3
from botocore.config import Config
s3 = boto3.client("s3", endpoint_url="$ENDPOINT",
    aws_access_key_id="$ACCESS_KEY",
    aws_secret_access_key="$SECRET_KEY",
    region_name="garage", config=Config(s3={"addressing_style": "path"}))
for obj in s3.list_objects_v2(Bucket="$BUCKET").get("Contents", []):
    print(f"{obj['Key']:50} {obj['Size']:>8} bytes")
PY

# How to GET a file Sebastian sent you:
python3 - <<'PY'
import boto3
from botocore.config import Config
s3 = boto3.client("s3", endpoint_url="$ENDPOINT",
    aws_access_key_id="$ACCESS_KEY",
    aws_secret_access_key="$SECRET_KEY",
    region_name="garage", config=Config(s3={"addressing_style": "path"}))
data = s3.get_object(Bucket="$BUCKET",
                     Key="from-mac/instructions.md")["Body"].read()
open("./instructions.md", "wb").write(data)
print(f"got {len(data)} bytes")
PY
EOF
)"

awscli_block="$(cat <<EOF
# First-time profile setup (run once):
aws configure set aws_access_key_id "$ACCESS_KEY" --profile garagetytus
aws configure set aws_secret_access_key "$SECRET_KEY" --profile garagetytus
aws configure set region garage --profile garagetytus

# How to PUT a file (Sebastian or other pods will see it):
aws s3 cp ./your-file.md s3://$BUCKET/from-$POD/your-file.md \\
    --endpoint $ENDPOINT --profile garagetytus

# How to LIST what's in the bucket:
aws s3 ls s3://$BUCKET/ --recursive \\
    --endpoint $ENDPOINT --profile garagetytus

# How to GET a file Sebastian sent you:
aws s3 cp s3://$BUCKET/from-mac/instructions.md ./ \\
    --endpoint $ENDPOINT --profile garagetytus
EOF
)"

footer="$(cat <<EOF
NAMING CONVENTION inside this bucket:
- Files YOU produce → prefix with from-$POD/
  e.g. s3://$BUCKET/from-$POD/result.json
- Files Sebastian sent you → look in from-mac/
  e.g. s3://$BUCKET/from-mac/instructions.md
- Files for ALL pods in this bucket → prefix with broadcast/
  e.g. s3://$BUCKET/broadcast/2026-04-26-news.md

WHAT NOT TO PUT IN THIS BUCKET:
- Secrets / API keys / passwords (this bucket is shared)
- Multi-GB blobs without explicit user approval (disk is finite)
- Conversational memory or chat history (use Brain instead)

WHEN UNSURE which bucket to use, or whether something belongs
in S3 vs Brain, ASK SEBASTIAN. Don't guess — wrong bucket =
wrong audience.

If the endpoint refuses connections, tell Sebastian; don't
loop on retries.
EOF
)"

case "$STYLE" in
    boto3)   prompt=$'\n'"$header"$'\n\n'"$boto3_block"$'\n\n'"$footer"$'\n' ;;
    aws-cli) prompt=$'\n'"$header"$'\n\n'"$awscli_block"$'\n\n'"$footer"$'\n' ;;
    both)    prompt=$'\n'"$header"$'\n\n--- boto3 (Python) recipes (use these in tytus pods) ---\n\n'"$boto3_block"$'\n\n--- aws CLI recipes (use these in environments with aws CLI) ---\n\n'"$awscli_block"$'\n\n'"$footer"$'\n' ;;
esac
prompt="${prompt#?}"  # trim leading newline

if [[ "$COPY" -eq 1 ]]; then
    if command -v pbcopy >/dev/null 2>&1; then
        printf '%s' "$prompt" | pbcopy
        printf 'garagetytus-agent-prompt: copied to clipboard (also printed below)\n\n' >&2
    elif command -v xclip >/dev/null 2>&1; then
        printf '%s' "$prompt" | xclip -selection clipboard
        printf 'garagetytus-agent-prompt: copied to clipboard via xclip (also printed below)\n\n' >&2
    elif command -v wl-copy >/dev/null 2>&1; then
        printf '%s' "$prompt" | wl-copy
        printf 'garagetytus-agent-prompt: copied to clipboard via wl-copy (also printed below)\n\n' >&2
    else
        printf 'garagetytus-agent-prompt: no clipboard tool found (need pbcopy/xclip/wl-copy); printing only\n\n' >&2
    fi
fi

printf '%s\n' "$prompt"
