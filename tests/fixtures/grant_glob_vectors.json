{
  "//": "Shared glob-semantics fixture for grant-scope matching. Exercised by Python (tests/test_user_grants.py) and Rust (capability::user_grants::tests). Drift fails CI. See spec/USER_GRANTS.md §4.",
  "schema_version": 1,
  "vectors": [
    {
      "name": "exact_match",
      "scope_glob": "/Users/sebastian/code/README.md",
      "path": "/Users/sebastian/code/README.md",
      "match": true
    },
    {
      "name": "exact_non_match",
      "scope_glob": "/Users/sebastian/code/README.md",
      "path": "/Users/sebastian/code/CHANGELOG.md",
      "match": false
    },
    {
      "name": "double_star_descends_one_level",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "/Users/sebastian/code/foo.md",
      "match": true
    },
    {
      "name": "double_star_descends_many_levels",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "/Users/sebastian/code/a/b/c/d/e.md",
      "match": true
    },
    {
      "name": "double_star_does_not_match_parent",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "/Users/sebastian/code",
      "match": false
    },
    {
      "name": "double_star_does_not_match_sibling",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "/Users/sebastian/other/foo.md",
      "match": false
    },
    {
      "name": "single_star_matches_one_segment",
      "scope_glob": "/Users/sebastian/tmp/*",
      "path": "/Users/sebastian/tmp/file.txt",
      "match": true
    },
    {
      "name": "single_star_rejects_deeper_segment",
      "scope_glob": "/Users/sebastian/tmp/*",
      "path": "/Users/sebastian/tmp/sub/file.txt",
      "match": false
    },
    {
      "name": "single_star_extension_filter_hit",
      "scope_glob": "/tmp/*.md",
      "path": "/tmp/foo.md",
      "match": true
    },
    {
      "name": "single_star_extension_filter_miss",
      "scope_glob": "/tmp/*.md",
      "path": "/tmp/foo.txt",
      "match": false
    },
    {
      "name": "double_star_extension_filter_hit",
      "scope_glob": "/Users/sebastian/code/**/*.rs",
      "path": "/Users/sebastian/code/src/main/lib.rs",
      "match": true
    },
    {
      "name": "double_star_extension_filter_miss",
      "scope_glob": "/Users/sebastian/code/**/*.rs",
      "path": "/Users/sebastian/code/src/main/lib.py",
      "match": false
    },
    {
      "name": "path_with_spaces_hit",
      "scope_glob": "/Users/sebastian/My Docs/**",
      "path": "/Users/sebastian/My Docs/report.md",
      "match": true
    },
    {
      "name": "path_with_dots_hit",
      "scope_glob": "/Users/sebastian/.config/**",
      "path": "/Users/sebastian/.config/makakoo/grants.json",
      "match": true
    },
    {
      "name": "prefix_rejection",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "/Users/sebastian/code-archive/legacy.md",
      "match": false
    },
    {
      "name": "sibling_directory_rejection",
      "scope_glob": "/Users/sebastian/a/**",
      "path": "/Users/sebastian/ab/file.md",
      "match": false
    },
    {
      "name": "root_scope_trivially_matches",
      "scope_glob": "/**",
      "path": "/any/path/file.md",
      "match": true,
      "note": "v1 scope parsers MAY still refuse '/' at the handler layer (LD#2 guardrail); this vector just pins glob-match semantics"
    },
    {
      "name": "empty_path_rejection",
      "scope_glob": "/Users/sebastian/code/**",
      "path": "",
      "match": false
    }
  ]
}
